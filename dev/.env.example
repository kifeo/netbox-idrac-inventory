# Copy to dev/.env and fill in the Dell server's iDRAC credentials.
# These reach both NetBox and the RQ worker (which runs the sync job).

# Default iDRAC login used when a Dell server has no per-device username.
IDRAC_USERNAME=root
IDRAC_PASSWORD=changeme

# iDRAC certs are usually self-signed -> keep verification off for testing.
IDRAC_VERIFY_SSL=false
IDRAC_TIMEOUT=30

# Pin a NetBox version if you don't want the rolling v4.2 tag.
# NETBOX_VERSION=v4.2
